# Address of the FastAPI backend. On another computer use the server IP address.
ApiBaseUrl=http://localhost:8000

# Leave empty to print to the Windows default printer, or enter its exact name.
PrinterName=

# Terminal screen mode.
FullScreen=true

# Thermal receipt paper width and additional feed after the final printed line.
ReceiptWidthMm=80
ReceiptBottomFeedMm=5

# PNG image displayed on the right side for online booking.
OnlineQrImage=online-qr.png
